// ============================================================================
// SYNTROPY — MERGED SCHEMA
// ============================================================================
// Contains: Social, Governance, Environmental.
// Gamification is not on main yet — add it here when that branch merges.
//
// NOTE FOR THE TEAM:
//   - Environmental uses a real `Department` table with UUID FKs.
//   - Social and Governance still store `department` as a free-text String.
//   - These must be reconciled before Department Score / Overall ESG Score
//     can work (PS §5). Environmental's shape is the one that supports it.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Shared Master Data ──────────────────────────────────────────────────────

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now()) @map("created_at")

  carbonTransactions CarbonTransaction[]
  environmentalGoals EnvironmentalGoal[]

  @@map("departments")
}

// ─── Social Module ───────────────────────────────────────────────────────────

model CsrActivity {
  id              String   @id @default(cuid())
  title           String
  description     String
  category        String // Environment, Community, Education, Health
  department      String
  location        String
  date            DateTime
  durationHours   Float
  maxParticipants Int
  status          String   @default("Draft") // Draft, Active, Completed, Cancelled
  organizer       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  participations EmployeeParticipation[]

  @@map("csr_activities")
}

model EmployeeParticipation {
  id              String    @id @default(cuid())
  activityId      String
  employeeName    String
  employeeId      String
  department      String
  proof           String?
  approvalStatus  String    @default("Pending") // Pending, Approved, Rejected
  pointsEarned    Int       @default(0)
  completionDate  DateTime?
  registeredDate  DateTime  @default(now())
  reviewedBy      String?
  reviewedDate    DateTime?
  rejectionReason String?

  activity CsrActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, employeeId])
  @@map("employee_participations")
}

model DiversityMetric {
  id         String   @id @default(cuid())
  department String
  category   String // Gender, Ethnicity, Age Group, Disability
  label      String // e.g. "Female", "25-34", "Asian"
  value      Int
  total      Int
  period     String // e.g. "Q2 2025"
  year       Int
  createdAt  DateTime @default(now())

  @@map("diversity_metrics")
}

model TrainingProgram {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String // ESG Awareness, Safety, Compliance, DEI
  department    String
  trainer       String
  durationHours Float
  mandatory     Boolean  @default(false)
  startDate     DateTime
  endDate       DateTime
  status        String   @default("Scheduled") // Scheduled, In Progress, Completed, Cancelled
  maxCapacity   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  completions TrainingCompletion[]

  @@map("training_programs")
}

model TrainingCompletion {
  id             String    @id @default(cuid())
  trainingId     String
  employeeName   String
  employeeId     String
  department     String
  completionDate DateTime?
  score          Float?
  status         String    @default("Not Started") // Not Started, In Progress, Completed, Failed
  certificateUrl String?
  createdAt      DateTime  @default(now())

  training TrainingProgram @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([trainingId, employeeId])
  @@map("training_completions")
}

// ─── Governance Module ───────────────────────────────────────────────────────

model Policy {
  id               String                  @id
  title            String
  department       String
  description      String
  status           String
  version          String
  effectiveDate    String
  acknowledgements PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id           String  @id
  policyId     String
  employeeName String
  department   String
  status       String
  dateSigned   String?
  policy       Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model Audit {
  id               String            @id
  title            String
  department       String
  auditor          String
  date             String
  findings         String
  status           String
  complianceIssues ComplianceIssue[]
}

model ComplianceIssue {
  id         String @id
  auditId    String
  issue      String
  severity   String
  department String
  status     String
  audit      Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

// ─── Environmental Module ────────────────────────────────────────────────────

enum EmissionFactorStatus {
  ACTIVE
  INACTIVE
}

enum CarbonSourceType {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
  MANUAL
}

enum EnvironmentalGoalStatus {
  ACTIVE
  ON_TRACK
  AT_RISK
  COMPLETED
  ARCHIVED
}

model EmissionFactor {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  category   String
  unit       String
  co2PerUnit Decimal              @db.Decimal(12, 4) @map("co2_per_unit")
  status     EmissionFactorStatus @default(ACTIVE)
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  carbonTransactions CarbonTransaction[]

  @@map("emission_factors")
}

model ProductESGProfile {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productName     String               @map("product_name")
  productCode     String               @unique @map("product_code")
  category        String?
  carbonFootprint Decimal?             @db.Decimal(12, 4) @map("carbon_footprint")
  sustainableFlag Boolean              @default(false) @map("sustainable_flag")
  notes           String?
  status          EmissionFactorStatus @default(ACTIVE)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@map("product_esg_profiles")
}

model CarbonTransaction {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId     String           @db.Uuid @map("department_id")
  emissionFactorId String           @db.Uuid @map("emission_factor_id")
  sourceType       CarbonSourceType @default(MANUAL) @map("source_type")
  sourceRef        String?          @map("source_ref")
  activityAmount   Decimal          @db.Decimal(14, 4) @map("activity_amount")
  co2Kg            Decimal          @db.Decimal(14, 4) @map("co2_kg")
  transactionDate  DateTime         @default(now()) @map("transaction_date")
  autoGenerated    Boolean          @default(false) @map("auto_generated")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  department     Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id], onDelete: Restrict)

  @@index([departmentId])
  @@index([emissionFactorId])
  @@index([sourceType, sourceRef])
  @@map("carbon_transactions")
}

model EnvironmentalGoal {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  departmentId String                  @db.Uuid @map("department_id")
  targetCo2Kg  Decimal                 @db.Decimal(14, 4) @map("target_co2_kg")
  currentCo2Kg Decimal                 @default(0) @db.Decimal(14, 4) @map("current_co2_kg")
  deadline     DateTime
  status       EnvironmentalGoalStatus @default(ACTIVE)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@map("environmental_goals")
}